<%- include('../partials/header', { title: 'Register' }) %>

<section class="auth-section">
  <div class="auth-card">
    <div class="auth-logo">
      <span class="auth-logo-icon">🐾</span>
    </div>
    <h1>Create Account</h1>
    <p class="auth-sub">Join the Curious Critters family</p>

    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

    <form action="/auth/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required placeholder="Your Name" autocomplete="name">
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Min 8 characters" autocomplete="new-password">
      </div>
      <div class="form-group">
        <label for="address">Address <span class="optional">(optional)</span></label>
        <input type="text" id="address" name="address" placeholder="123 Void St, Dimension 4" autocomplete="street-address">
      </div>
      <div class="form-group">
        <label for="phone">Phone <span class="optional">(optional)</span></label>
        <input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" autocomplete="tel">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Create Account</button>
    </form>
    <p class="auth-switch">Already have an account? <a href="/auth/login">Sign in</a></p>
  </div>
</section>

<%- include('../partials/footer') %>
