<%- include('../partials/header', { title: 'Sign In' }) %>

<section class="auth-section">
  <div class="auth-card">
    <div class="auth-logo">
      <span class="auth-logo-icon">🐾</span>
    </div>
    <h1>Welcome Back</h1>
    <p class="auth-sub">Sign in to your Curious Critters account</p>

    <% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>
    <% if (success && success.length) { %><div class="flash success"><%= success %></div><% } %>

    <form action="/auth/login" method="POST" class="auth-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" autocomplete="current-password">
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign In</button>
    </form>
    <p class="auth-switch">No account? <a href="/auth/register">Register here</a></p>
  </div>
</section>

<%- include('../partials/footer') %>
