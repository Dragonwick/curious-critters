<%- include('partials/header', { title: 'Error' }) %>

<section class="section" style="display:flex;justify-content:center;align-items:center;min-height:calc(100vh - 200px)">
  <div style="text-align:center;max-width:460px">
    <div class="error-code">4XX</div>
    <h2>Something went wrong</h2>
    <p class="muted" style="margin:0.75rem 0 2rem"><%= message || 'An unexpected error occurred.' %></p>
    <div style="display:flex;gap:1rem;justify-content:center">
      <a href="/" class="btn btn-primary">Go Home</a>
      <a href="/shop" class="btn btn-ghost">Browse Shop</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
