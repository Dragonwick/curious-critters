<%- include('../partials/header', { title: 'Cart' }) %>

<section class="section">
  <div class="page-header">
    <h1 class="page-title">Your Cart</h1>
  </div>

  <% if (error && error.length) { %><div class="flash-wrap"><div class="flash error"><%= error %></div></div><% } %>
  <% if (success && success.length) { %><div class="flash-wrap"><div class="flash success"><%= success %></div></div><% } %>

  <% if (items.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🧺</div>
      <p>Your cart is empty. Nothing stirs within.</p>
      <a href="/shop" class="btn btn-primary">Browse the Collection</a>
    </div>
  <% } else { %>
  <div class="cart-layout">
    <div>
      <div class="cart-items-card">
        <div class="cart-items-header">
          <span>Item</span>
          <span></span>
          <span>Qty</span>
          <span style="text-align:right">Total</span>
          <span></span>
        </div>
        <% for (const item of items) { %>
        <div class="cart-item">
          <img class="cart-item-img" src="<%= item.image_path %>" alt="<%= item.name %>" onerror="this.src='/images/default.png'">
          <div class="cart-item-info">
            <h3><a href="/shop/<%= item.id %>"><%= item.name %></a></h3>
            <p class="cart-unit-price">$<%= item.unitPrice.toFixed(2) %> each</p>
          </div>
          <form action="/cart/update" method="POST" class="cart-qty-form">
            <input type="hidden" name="product_id" value="<%= item.id %>">
            <input type="number" name="qty" value="<%= item.qty %>" min="0" max="<%= item.quantity %>" class="cart-qty-input">
            <button type="submit" class="btn btn-ghost btn-sm" data-no-load>Update</button>
          </form>
          <div class="cart-line-total">$<%= item.lineTotal.toFixed(2) %></div>
          <form action="/cart/remove" method="POST">
            <input type="hidden" name="product_id" value="<%= item.id %>">
            <button type="submit" class="cart-remove-btn" title="Remove item" data-no-load>✕</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>

    <div class="cart-summary">
      <h2>Order Summary</h2>

      <div class="summary-row">
        <span>Subtotal</span><span>$<%= subtotal.toFixed(2) %></span>
      </div>

      <% if (discountCode && discountAmount > 0) { %>
      <div class="summary-row discount-row">
        <span>Discount (<%= discountCode %>)</span>
        <span>−$<%= discountAmount.toFixed(2) %></span>
      </div>
      <% } %>

      <div class="summary-row">
        <span>Tax (8.25%)</span><span>$<%= tax.toFixed(2) %></span>
      </div>
      <div class="summary-row total-row">
        <span>Total</span><span>$<%= total.toFixed(2) %></span>
      </div>

      <% if (discountCode) { %>
        <div class="applied-code">
          <span><%= discountCode %> · <%= discountMsg %></span>
          <form action="/cart/remove-discount" method="POST" style="margin:0">
            <button type="submit" class="btn btn-ghost btn-sm" data-no-load>Remove</button>
          </form>
        </div>
      <% } else { %>
        <form action="/cart/discount" method="POST" class="discount-form">
          <input type="text" name="code" placeholder="Discount code" class="discount-input" autocomplete="off">
          <button type="submit" class="btn btn-ghost" data-no-load>Apply</button>
        </form>
      <% } %>

      <a href="/cart/checkout" class="btn btn-primary btn-lg btn-full">Proceed to Checkout →</a>
      <a href="/shop" class="btn btn-ghost btn-full">Continue Shopping</a>
    </div>
  </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
