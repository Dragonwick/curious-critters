<%- include('./partials/admin-header', { title: 'Dashboard', active: 'dashboard' }) %>

<div class="admin-page-header">
  <div>
    <h1>Dashboard</h1>
    <p>Welcome back — here's what's happening in your store.</p>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon-wrap">
      <span class="stat-icon">👤</span>
    </div>
    <div class="stat-value"><%= stats.users %></div>
    <div class="stat-label">Customers</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap">
      <span class="stat-icon">🦕</span>
    </div>
    <div class="stat-value"><%= stats.products %></div>
    <div class="stat-label">Active Products</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap">
      <span class="stat-icon">📦</span>
    </div>
    <div class="stat-value"><%= stats.orders %></div>
    <div class="stat-label">Total Orders</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon-wrap">
      <span class="stat-icon">💰</span>
    </div>
    <div class="stat-value">$<%= Number(stats.revenue || 0).toFixed(0) %></div>
    <div class="stat-label">Total Revenue</div>
  </div>
</div>

<div class="admin-section">
  <div class="admin-section-header">
    <h2>Recent Orders</h2>
    <a href="/admin/orders" class="btn btn-ghost btn-sm">View All →</a>
  </div>
  <div class="admin-table-wrap">
    <% if (recentOrders.length === 0) { %>
      <div class="table-empty">No orders have been placed yet.</div>
    <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Customer</th>
          <th>Items</th>
          <th>Total</th>
          <th>Status</th>
          <th>Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const o of recentOrders) { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.customer_name %></td>
          <td><%= o.item_count || '—' %></td>
          <td><span class="revenue-text">$<%= o.total.toFixed(2) %></span></td>
          <td><span class="status-badge"><%= o.status %></span></td>
          <td class="muted small"><%= new Date(o.placed_at).toLocaleDateString() %></td>
          <td><a href="/admin/orders/<%= o.id %>" class="btn btn-ghost btn-sm">View</a></td>
        </tr>
        <% } %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<%- include('./partials/admin-footer') %>
