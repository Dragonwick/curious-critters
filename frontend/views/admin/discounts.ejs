<%- include('./partials/admin-header', { title: 'Discount Codes', active: 'discounts' }) %>

<div class="admin-page-header">
  <div>
    <h1>Discount Codes</h1>
    <p>Create and manage promotional codes for customers</p>
  </div>
</div>

<% if (success && success.length) { %><div class="flash success" style="margin-bottom:1.5rem"><%= success %></div><% } %>
<% if (error && error.length) { %><div class="flash error" style="margin-bottom:1.5rem"><%= error %></div><% } %>

<div class="admin-detail-layout">
  <div class="admin-form-card">
    <div class="admin-form-card-header"><h2>Create New Code</h2></div>
    <div class="admin-form-card-body">
      <form action="/admin/discounts/new" method="POST" class="admin-form">
        <div class="form-row">
          <div class="form-group">
            <label>Code</label>
            <input type="text" name="code" placeholder="e.g. SUMMER20" required style="text-transform:uppercase;font-family:monospace;letter-spacing:0.06em">
          </div>
          <div class="form-group">
            <label>Type</label>
            <select name="type">
              <option value="percent">Percent Off (%)</option>
              <option value="flat">Flat Amount ($)</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Value</label>
            <input type="number" name="value" step="0.01" min="0" placeholder="e.g. 10 for 10% or $10" required>
          </div>
          <div class="form-group">
            <label>Uses Remaining</label>
            <input type="number" name="uses_remaining" value="-1">
            <span class="form-hint">Use −1 for unlimited uses</span>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Create Code</button>
      </form>
    </div>
  </div>

  <div>
    <div class="admin-section-header">
      <h2>All Codes (<%= codes.length %>)</h2>
    </div>
    <div class="admin-table-wrap">
      <% if (codes.length === 0) { %>
        <div class="table-empty">No discount codes yet. Create one to get started.</div>
      <% } else { %>
      <table class="data-table">
        <thead>
          <tr><th>Code</th><th>Type</th><th>Value</th><th>Uses Left</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
          <% for (const c of codes) { %>
          <tr class="<%= !c.active ? 'row-inactive' : '' %>">
            <td><span class="discount-chip"><%= c.code %></span></td>
            <td><span class="muted small"><%= c.type === 'percent' ? 'Percent' : 'Flat $' %></span></td>
            <td><strong><%= c.type === 'percent' ? c.value + '%' : '$' + c.value.toFixed(2) %></strong></td>
            <td><%= c.uses_remaining === -1 ? '∞ unlimited' : c.uses_remaining %></td>
            <td>
              <span class="<%= c.active ? 'badge-active' : 'badge-inactive' %>">
                <%= c.active ? 'Active' : 'Disabled' %>
              </span>
            </td>
            <td>
              <form action="/admin/discounts/<%= c.id %>/toggle" method="POST">
                <button type="submit" class="btn btn-ghost btn-sm">
                  <%= c.active ? 'Disable' : 'Enable' %>
                </button>
              </form>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('./partials/admin-footer') %>
