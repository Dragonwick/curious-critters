<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Admin · Curious Critters</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<div class="admin-layout">
  <aside class="admin-sidebar">
    <a href="/" class="admin-logo">
      <span class="admin-logo-icon">🐾</span>
      <span class="admin-logo-text">
        <span class="admin-logo-title">Curious Critters</span>
        <span class="admin-logo-sub">Admin Panel</span>
      </span>
    </a>

    <nav class="admin-nav">
      <span class="admin-nav-label">Overview</span>
      <a href="/admin" class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
        <span class="nav-icon">📊</span> Dashboard
      </a>

      <span class="admin-nav-label">Catalog</span>
      <a href="/admin/products" class="<%= typeof active !== 'undefined' && active === 'products' ? 'active' : '' %>">
        <span class="nav-icon">🦕</span> Products
      </a>
      <a href="/admin/discounts" class="<%= typeof active !== 'undefined' && active === 'discounts' ? 'active' : '' %>">
        <span class="nav-icon">🏷</span> Discount Codes
      </a>

      <span class="admin-nav-label">Operations</span>
      <a href="/admin/orders" class="<%= typeof active !== 'undefined' && active === 'orders' ? 'active' : '' %>">
        <span class="nav-icon">📦</span> Orders
      </a>
      <a href="/admin/users" class="<%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">
        <span class="nav-icon">👤</span> Users
      </a>
    </nav>

    <div class="admin-sidebar-footer">
      <a href="/"><span>←</span> View Storefront</a>
      <a href="/auth/logout"><span>⎋</span> Logout</a>
    </div>
  </aside>

  <main class="admin-main">
