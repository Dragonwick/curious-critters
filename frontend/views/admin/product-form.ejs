<%- include('./partials/admin-header', { title: product ? 'Edit Product' : 'New Product', active: 'products' }) %>

<div class="admin-page-header">
  <div>
    <h1><%= product ? 'Edit: ' + product.name : 'New Product' %></h1>
    <p><%= product ? 'Update product details, pricing, and inventory' : 'Add a new item to your catalog' %></p>
  </div>
  <a href="/admin/products" class="btn btn-ghost">← Back to Products</a>
</div>

<% if (error && error.length) { %><div class="flash error" style="margin-bottom:1.5rem"><%= error %></div><% } %>

<div class="admin-form-card">
  <div class="admin-form-card-header"><h2>Product Details</h2></div>
  <div class="admin-form-card-body">
    <form action="/admin/products/<%= product ? product.id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data" class="admin-form">

      <div class="form-row">
        <div class="form-group">
          <label>Name <span style="color:var(--danger)">*</span></label>
          <input type="text" name="name" value="<%= product ? product.name : '' %>" required placeholder="Product name">
        </div>
        <div class="form-group">
          <label>Category</label>
          <input type="text" name="category" value="<%= product ? product.category || '' : '' %>" placeholder="e.g. Pets, Food, Accessories">
        </div>
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea name="description" rows="4" placeholder="Describe this product…"><%= product ? product.description || '' : '' %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Price <span style="color:var(--danger)">*</span></label>
          <input type="number" name="price" step="0.01" min="0" value="<%= product ? product.price : '' %>" required placeholder="0.00">
        </div>
        <div class="form-group">
          <label>Quantity in Stock <span style="color:var(--danger)">*</span></label>
          <input type="number" name="quantity" min="0" value="<%= product ? product.quantity : '0' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label>Product Image</label>
        <% if (product && product.image_path) { %>
          <img src="<%= product.image_path %>" alt="" class="current-image" onerror="this.src='/images/default.png'">
          <p class="form-hint">Upload a new image to replace the current one.</p>
        <% } %>
        <input type="file" name="image" accept="image/*">
      </div>

      <div class="form-row">
        <div class="form-group" style="justify-content:flex-end;padding-top:1.4rem">
          <label class="checkbox-group">
            <input type="checkbox" name="on_sale" value="1" <%= product && product.on_sale ? 'checked' : '' %>>
            <span>Mark as On Sale</span>
          </label>
        </div>
        <div class="form-group sale-price-group">
          <label>Sale Price</label>
          <input type="number" name="sale_price" step="0.01" min="0" value="<%= product && product.sale_price ? product.sale_price : '' %>" placeholder="Discounted price">
        </div>
      </div>

      <% if (product) { %>
      <div class="form-group">
        <label class="checkbox-group">
          <input type="checkbox" name="active" value="1" <%= product.active ? 'checked' : '' %>>
          <span>Active — visible in storefront</span>
        </label>
      </div>
      <% } %>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><%= product ? 'Save Changes' : 'Create Product' %></button>
        <a href="/admin/products" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('./partials/admin-footer') %>
