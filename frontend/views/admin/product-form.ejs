<%- include('./partials/admin-header', { title: product ? 'Edit Product' : 'New Product', active: 'products' }) %>

<div class="admin-page-header">
  <h1><%= product ? 'Edit: ' + product.name : 'New Product' %></h1>
  <a href="/admin/products" class="btn btn-ghost">← Back</a>
</div>

<% if (error && error.length) { %><div class="flash error"><%= error %></div><% } %>

<div class="admin-form-card">
  <form action="/admin/products/<%= product ? product.id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data" class="admin-form">

    <div class="form-row">
      <div class="form-group">
        <label>Name *</label>
        <input type="text" name="name" value="<%= product ? product.name : '' %>" required>
      </div>
      <div class="form-group">
        <label>Category</label>
        <input type="text" name="category" value="<%= product ? product.category || '' : '' %>" placeholder="e.g. Pets, Food, Accessories">
      </div>
    </div>

    <div class="form-group">
      <label>Description</label>
      <textarea name="description" rows="4"><%= product ? product.description || '' : '' %></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Price *</label>
        <input type="number" name="price" step="0.01" min="0" value="<%= product ? product.price : '' %>" required>
      </div>
      <div class="form-group">
        <label>Quantity *</label>
        <input type="number" name="quantity" min="0" value="<%= product ? product.quantity : '0' %>" required>
      </div>
    </div>

    <div class="form-group">
      <label>Product Image</label>
      <% if (product && product.image_path) { %>
        <img src="<%= product.image_path %>" alt="" class="current-image" onerror="this.src='/images/default.png'">
        <p class="muted small">Upload a new image to replace current.</p>
      <% } %>
      <input type="file" name="image" accept="image/*">
    </div>

    <div class="form-row">
      <div class="form-group checkbox-group">
        <label>
          <input type="checkbox" name="on_sale" value="1" <%= product && product.on_sale ? 'checked' : '' %>>
          On Sale
        </label>
      </div>
      <div class="form-group">
        <label>Sale Price (if on sale)</label>
        <input type="number" name="sale_price" step="0.01" min="0" value="<%= product && product.sale_price ? product.sale_price : '' %>">
      </div>
    </div>

    <% if (product) { %>
    <div class="form-group checkbox-group">
      <label>
        <input type="checkbox" name="active" value="1" <%= product.active ? 'checked' : '' %>>
        Active (visible in store)
      </label>
    </div>
    <% } %>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= product ? 'Save Changes' : 'Create Product' %></button>
      <a href="/admin/products" class="btn btn-ghost">Cancel</a>
    </div>
  </form>
</div>

<%- include('./partials/admin-footer') %>
